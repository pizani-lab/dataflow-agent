# DataFlow Agent - Variáveis de Ambiente
# Copie este arquivo para .env e configure conforme necessário

# ================================================
# MODO DESENVOLVIMENTO (padrão - sem config needed)
# ================================================
# Este arquivo está configured para desenvolvimento local "out of the box".
# Basta copiar para .env e rodar:
#   cd backend && pip install -r requirements.txt
#   python manage.py migrate
#   python manage.py runserver
#
# O sistema usará automaticamente:
#   - SQLite como banco de dados
#   - Ollama em localhost:11434
#   - Canal em memória (sem Redis)

# ================================================
# PRODUÇÃO - Configure as variáveis abaixo
# ================================================

# Django
SECRET_KEY=sua-chave-secreta-aqui-minimo-32-caracteres
DEBUG=False
ALLOWED_HOSTS=localhost,seu-dominio.com

# Database (use postgresql para produção)
DB_ENGINE=postgresql  # ou sqlite para desenvolvimento
DB_NAME=dataflow_agent
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_HOST=localhost
DB_PORT=5432

# Redis (para Celery e Channels em produção)
USE_REDIS=True
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/1

# Ollama (OBRIGATÓRIO para agent funcionar)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Anthropic (opcional - para usar Claude API)
# ANTHROPIC_API_KEY=sk-ant-...

# Mock do agent (True = simulate respostas, False = usa Ollama real)
AGENT_MOCK=False

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5101

# Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=sua-senha-aqui

# Frontend (opcional)
# VITE_API_URL=https://api-seu-dominio.com